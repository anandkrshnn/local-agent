# ============================================================
# Local Agent v4.0 - Production Environment Configuration
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# Database type: 'sqlite' (development) or 'postgres' (production)
DB_TYPE=sqlite

# SQLite (development) - only used when DB_TYPE=sqlite
SQLITE_PATH=./data/local_agent.db

# PostgreSQL (production) - only used when DB_TYPE=postgres
DATABASE_URL=postgresql://agent_user:secure_password@localhost:5432/local_agent

# ============================================================
# API SECURITY
# ============================================================
AGENT_API_KEY=local-agent-key-2024
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Audit encryption key (generate with: openssl rand -hex 32)
AUDIT_ENCRYPTION_KEY=

# ============================================================
# CORS - Allowed origins
# ============================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:8000

# ============================================================
# OLLAMA CONFIGURATION
# ============================================================
OLLAMA_ENDPOINT=http://localhost:11434
DEFAULT_MODEL=phi3:mini

# ============================================================
# OPTIONAL CLOUD API KEYS
# ============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ============================================================
# EMAIL CONFIGURATION
# ============================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ============================================================
# SECURITY
# ============================================================
SANDBOX_PATH=~/LocalAgentSandbox
MAX_SESSIONS=100
REQUEST_TIMEOUT=120

# ============================================================
# PERFORMANCE
# ============================================================
ENABLE_GPU=true
ENABLE_CACHE=true
CACHE_SIZE=1000
SQL_ECHO=false

# ============================================================
# RAG KNOWLEDGE BASE
# ============================================================
KNOWLEDGE_BASE_PATH=./knowledge_base

# ============================================================
# SSO (Enterprise)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LDAP Configuration
LDAP_SERVER=
LDAP_BASE_DN=
LDAP_USER_RDN=uid

# SAML Configuration
SAML_SP_ENTITY_ID=
SAML_ACS_URL=
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_CERT=
